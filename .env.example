# SourceRank Configuration (optional)
# Override default scoring weights (each 0.0 - 1.0, must sum to 1.0)
# SOURCERANK_RECENCY_WEIGHT=0.25
# SOURCERANK_AUTHORITY_WEIGHT=0.25
# SOURCERANK_CITATION_WEIGHT=0.25
# SOURCERANK_FACTUAL_WEIGHT=0.25

# Recency half-life in days (sources lose half their recency score after this many days)
# SOURCERANK_RECENCY_HALF_LIFE_DAYS=365

# Citation saturation (number of citations for a perfect 1.0 score)
# SOURCERANK_CITATION_SATURATION=10

# Logging level
# SOURCERANK_LOG_LEVEL=INFO
